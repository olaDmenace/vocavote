# Supabase — public (safe to ship to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# Supabase — server-only (NEVER prefix with NEXT_PUBLIC_, NEVER import into client components)
# Grab from: https://supabase.com/dashboard/project/<project-ref>/settings/api-keys
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# App
# Origin used by server actions and route handlers. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Salt for sha256 IP hashing in votes/login_attempts (any sufficiently long random string)
IP_HASH_SALT=change-me-to-a-long-random-string
